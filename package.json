{
  "name": "standard-tool",
  "version": "0.0.6",
  "description": "One type for an LLM tool — define it once, use it with any provider, SDK, or framework. Input & output validated via Standard Schema and emitted as JSON Schema. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "build:site": "node scripts/build-site.mjs",
    "prepare": "tsc",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "test": "npm run build && npm run typecheck && npm run lint && node --test",
    "patch": "npm test && npm version patch",
    "postversion": "npm run build && npm publish && git push && git push --tags"
  },
  "keywords": [
    "standard-schema",
    "standard-json-schema",
    "json-schema",
    "llm",
    "tool",
    "function-calling",
    "openai",
    "mcp",
    "validation",
    "zod",
    "valibot",
    "arktype"
  ],
  "author": "Andrey Gubanov",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finom/standard-tool.git"
  },
  "homepage": "https://github.com/finom/standard-tool#readme",
  "bugs": {
    "url": "https://github.com/finom/standard-tool/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@orpc/server": "^1.14.7",
    "@trpc/server": "^11.18.0",
    "@types/node": "^25.9.1",
    "@valibot/to-json-schema": "^1.7.1",
    "arktype": "^2.2.3",
    "typescript": "^7.0.2",
    "valibot": "^1.4.2",
    "zod": "^4.4.3"
  }
}
